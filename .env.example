# Copy this file to .env and fill values before running
POSTGRES_USER=cm_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cm_db

# Connection string used by the app
# Example: postgresql://cm_user:changeme@db:5432/cm_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Optional: override app port
PORT=3000
